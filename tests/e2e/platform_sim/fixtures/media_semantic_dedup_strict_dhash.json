{
  "name": "media_semantic_dedup_strict_dhash",
  "adapter": {
    "instanceId": "sim-main",
    "platform": "sim",
    "selfId": "bot-self"
  },
  "mediaAssets": [
    {
      "name": "source",
      "color": [24, 32, 40],
      "repeat": 1
    },
    {
      "name": "mirror",
      "color": [24, 32, 40],
      "repeat": 2
    }
  ],
  "config": {
    "adapter_instances": [
      {
        "id": "sim-main",
        "platform": "sim"
      }
    ],
    "plugins": [],
    "bots": []
  },
  "modelRuntime": {
    "fakeCompletion": {
      "text": "{\"kind\":\"meme_image\",\"digest\":\"同一张图的重复语义\",\"confidence_band\":\"high\",\"reason\":\"strict dhash matched\"}",
      "inputTokens": 4,
      "outputTokens": 2
    },
    "providers": [
      {
        "id": "stub-provider",
        "type": "openai",
        "displayName": "Stub Provider"
      }
    ],
    "models": [
