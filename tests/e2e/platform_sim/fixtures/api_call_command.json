{
  "name": "api_call_command",
  "adapter": {
    "instanceId": "sim-main",
    "platform": "sim",
    "selfId": "bot-self"
  },
  "commands": [
    {
      "name": "poke",
      "kind": "api",
      "api": {
        "method": "internal.sim.poke",
        "params": {
          "user_id": "{args}",
          "session_id": "{session_id}"
        }
      },
      "reply": "api ok: {method}"
    }
  ],
  "steps": [
    {
      "type": "message",
      "id": "msg-1",
      "session": {
        "type": "group",
        "channelId": "group-1",
        "channelName": "Test Group"
      },
      "sender": {
        "id": "user-1",
        "name": "Alice"
      },
      "content": "/poke user-2",
      "expectSentCount": 1
    }
  ],
  "expect": {
    "sent": [
      {
        "sessionId": "sim-main:group:group-1",
        "messageId": "sim-out-1",
        "text": "api ok: internal.sim.poke",
        "elements": [
          {
            "type": "text",
            "attrs": {
              "content": "api ok: internal.sim.poke"
            }
          }
        ]
      }
    ],
    "apiCalls": [
      {
        "method": "internal.sim.poke",
        "params": {
          "user_id": "user-2",
          "session_id": "sim-main:group:group-1"
        }
      }
    ],
    "messageLogs": {
      "sessionId": "sim-main:group:group-1",
      "countExact": 2,
      "incomingRoutingStatus": "dispatched",
      "roles": ["user", "assistant"],
      "senderIds": ["user-1", "bot-self"],
      "senderNames": ["Alice", ""],
      "platformMsgIds": ["msg-1", "sim-out-1"],
      "isRead": [false, true],
      "rawTexts": ["/poke user-2", "api ok: internal.sim.poke"],
      "contentElements": [
        [
          {
            "type": "text",
            "attrs": {
              "content": "/poke user-2"
            },
            "children": []
          }
        ],
        [
          {
            "type": "text",
            "attrs": {
              "content": "api ok: internal.sim.poke"
            },
            "children": []
          }
        ]
      ],
      "routingStatuses": ["dispatched", "pending"]
    }
  }
}
