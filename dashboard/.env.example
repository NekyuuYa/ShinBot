# Backend API Configuration
# Use a relative path by default so the production build works behind the
# same origin that serves the dashboard.
VITE_API_BASE_URL=/api/v1

# WebSocket Configuration
VITE_WS_BASE_URL=/ws
VITE_WS_LOGS_URL=/ws/logs
VITE_WS_STATUS_URL=/ws/status

# Application
VITE_APP_TITLE=ShinBot Dashboard
