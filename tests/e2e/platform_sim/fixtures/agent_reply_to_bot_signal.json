{
  "name": "agent_reply_to_bot_signal",
  "adapter": {
    "instanceId": "sim-main",
    "platform": "sim",
    "selfId": "bot-self"
  },
  "agentEntryProbe": {
    "enabled": true
  },
  "config": {
    "adapter_instances": [
      {
        "id": "sim-main",
        "platform": "sim"
      }
    ],
    "plugins": [],
    "bots": [
      {
        "id": "agent-bot",
        "display_name": "Agent Bot",
        "commands": {
          "enabled": true,
          "prefixes": ["/"]
        },
        "plugins": {
          "enabled": true,
          "enabled_plugins": ["*"]
        },
        "agent": {
          "mode": "full",
          "config": "agents/default.toml"
        },
        "bindings": [
          {
            "id": "agent-group",
            "adapter_instance_id": "sim-main",
            "session_patterns": ["group:group-1"],
            "priority": 10
          }
        ]
      }
    ]
  },
  "commands": [
    {
      "name": "ping",
      "reply": "pong: {args}"
    }
  ],
  "steps": [
    {
      "type": "message",
      "id": "msg-1",
      "session": {
        "type": "group",
        "channelId": "group-1",
        "channelName": "Agent Group"
      },
      "sender": {
        "id": "user-1",
        "name": "Alice"
      },
      "content": "/ping ok",
      "expectSentCount": 1
    },
    {
      "type": "message",
      "id": "msg-2",
      "session": {
        "type": "group",
        "channelId": "group-1",
        "channelName": "Agent Group"
      },
      "sender": {
        "id": "user-1",
        "name": "Alice"
      },
      "elements": [
        {
          "type": "quote",
          "attrs": {
            "id": "sim-out-1"
          }
        },
        {
          "type": "text",
          "attrs": {
            "content": " thanks"
          }
        }
      ],
      "expectSentCount": 1
    }
  ],
  "expect": {
    "sent": [
      {
        "sessionId": "sim-main:group:group-1",
        "messageId": "sim-out-1",
        "elements": [
          {
            "type": "text",
            "attrs": {
              "content": "pong: ok"
            }
          }
        ]
      }
    ],
    "agentEntrySignals": [
      {
        "sessionId": "sim-main:group:group-1",
        "botId": "agent-bot",
        "botBindingId": "agent-group",
        "botSessionId": "agent-bot:group:group-1",
        "eventType": "message-created",
        "senderId": "user-1",
        "messageLogId": true,
        "isReplyToBot": true
      }
    ],
    "messageLogs": {
      "sessionId": "sim-main:group:group-1",
      "countAtLeast": 3,
      "roles": ["user", "assistant", "user"],
      "incomingRoutingStatus": "dispatched",
      "senderIds": ["user-1", "bot-self", "user-1"],
      "senderNames": ["Alice", "", "Alice"],
      "platformMsgIds": ["msg-1", "sim-out-1", "msg-2"],
      "isRead": [false, true, false],
      "rawTexts": ["/ping ok", "pong: ok", " thanks"],
      "contentElements": [
        [
          {
            "type": "text",
            "attrs": {
              "content": "/ping ok"
            },
            "children": []
          }
        ],
        [
          {
            "type": "text",
            "attrs": {
              "content": "pong: ok"
            },
            "children": []
          }
        ],
        [
          {
            "type": "quote",
            "attrs": {
              "id": "sim-out-1"
            },
            "children": []
          },
          {
            "type": "text",
            "attrs": {
              "content": " thanks"
            },
            "children": []
          }
        ]
      ],
      "routingStatuses": ["dispatched", "pending", "dispatched"]
    }
  }
}
